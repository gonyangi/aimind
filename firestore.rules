rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // [보안 헬퍼 함수 1] 사용자가 로그인 상태인지 검증
    function isSignedIn() {
      return request.auth != null;
    }
    
    // [보안 헬퍼 함수 2] 로그인된 유저의 역할(role)을 users 테이블에서 실시간 조회
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // 1. 사용자(users) 프로필 테이블 규칙
    match /users/{userId} {
      // 본인 계정의 정보만 읽고 쓸 수 있도록 허용 (타인의 이름, 이메일 탈취 방지)
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // 2. 마음 일기장(diaries) 테이블 규칙
    match /diaries/{diaryId} {
      // 생성(Create): 로그인 상태이고, 데이터에 기록될 작성자 uid가 본인 uid와 일치하며, 학생 역할일 때만 생성 허용
      allow create: if isSignedIn() 
        && request.resource.data.studentUid == request.auth.uid
        && getUserRole() == 'student';
        
      // 조회(Read): 로그인 상태이고, 해당 일기의 작성자가 본인이거나, 조회하는 유저의 역할이 'teacher'(선생님)일 때만 허용
      allow read: if isSignedIn() 
        && (resource.data.studentUid == request.auth.uid || getUserRole() == 'teacher');
        
      // 수정 및 삭제(Update, Delete): 일기 데이터의 무결성과 보안을 위해 수정 및 삭제를 철저히 차단
      allow update, delete: if false;
    }
  }
}
